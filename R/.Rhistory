# Set working directory to folders containing files
setwd("~/UM/CDMetaPop/Kaeli_et_al/fake_runs/")
# Preallocate Het_df
Het_df <- tibble(Run = numeric(0), Year = character(0), Ohomo = numeric(0), Ohet = numeric(0), Ehet = numeric(0))
# Set the path to folders containing files (replace with an actual directory path)
dir_path <- "~/UM/CDMetaPop/Kaeli_et_al/fake_runs/"
# Get list of folders containing the files
list_folders <- list.dirs(dir_path, recursive = FALSE)
# Setup parallel backend
num_cores <- 3#parallel::detectCores() - 1
cl <- makeCluster(num_cores)
doParallel::registerDoParallel(cl)
# Process each folder in parallel
log_file <- "processing_log.txt"
results <- foreach(folder = list_folders, .combine = rbind, .packages = c("dplyr", "readr", "stringr", "gtools")) %dopar% {
# Catch errors for each folder
tryCatch({
# Get list of files in the folder
list_files <- list.files(folder, pattern = "ind", full.names = TRUE, recursive = TRUE)
# Exclude files with "Sample" in the name
indFiles <- grep("Sample", list_files, value = TRUE, invert = TRUE)
indFiles <- gtools::mixedsort(indFiles)
# Initialize results as an empty tibble with the correct column names
folder_results <- tibble(Run = numeric(0), Year = character(0), Ohomo = numeric(0), Ohet = numeric(0), Ehet = numeric(0))
# Process each file in the folder
for (file in indFiles) {
# Log processing file
write(paste("Processing file:", file, "\n"), file = log_file, append = TRUE)
fulldata <- read_csv(file, id = "file_name") %>%
mutate(Year = as.numeric(str_replace_all(file_name, ".*ind|\\.csv$", "")),
Run = as.numeric(str_extract(basename(folder), "\\d+")))  # # Extract numeric part of the folder name
# Filter and select required data
filtered_data <- fulldata %>%
filter(sex != "YY") %>%
distinct(ID, .keep_all = TRUE)
# Separate individual and genetic data
indData <- filtered_data %>%
select(1:21, which(names(fulldata) == "Year"), which(names(fulldata) == "Run")) #%>%
#mutate(Year = fulldata$Year, Run = fulldata$Run)
df <- filtered_data %>%
select(22:10021)
# Combine loci into single columns per locus
locus_cols <- seq(0, 4999)
firstcols <- paste("L", locus_cols, "A0", sep = "")
secondcols <- paste("L", locus_cols, "A1", sep = "")
# Combine alleles for all loci at once
for (i in 1:length(locus_cols)) {
df[[firstcols[i]]] <- paste0(df[[firstcols[i]]], df[[secondcols[i]]])
}
# Remove A1 columns
df[, secondcols] <- NULL
# Recode genotypes while handling NA values
df[,] <- df[,] %>%
mutate(across(everything(), ~ case_when(
. == "20" ~ 11,
. == "02" ~ 22,
. == "11" ~ 12,
TRUE ~ 99  # for other values or NAs
)))
# Calculate metrics
df$hom1ind <- rowSums(df == "11", na.rm = TRUE)
df$het1ind <- rowSums(df == "12", na.rm = TRUE)
df$hom2ind <- rowSums(df == "22", na.rm = TRUE)
df$Ohomo <- (df$hom1ind + df$hom2ind) / 5000  # divide by total loci to normalize
df$ohet <- df$het1ind / 5000
df$pi <- ((2 * df$hom1ind) + df$het1ind) / (2 * 5000)
df$qi <- 1 - df$pi
df$piqi <- 2 * df$pi * df$qi
# Combine with individual data
Fulldata2 <- cbind(indData, df)
# Summarize by Run and Year
meandf <- Fulldata2 %>%
group_by(Run, Year) %>%
summarise(
Ohomo = mean(Ohomo, na.rm = TRUE),
Ohet = mean(ohet, na.rm = TRUE),
Ehet = mean(piqi, na.rm = TRUE)
) %>%
ungroup()  # Remove grouping structure
# Append to folder results
folder_results <- bind_rows(folder_results, meandf)
# Write intermediate results to file after processing each folder
if (nrow(folder_results) > 0) {
folder_output_file <- file.path(folder, "H_folder_results.csv")
write_csv(folder_results, folder_output_file)
}
}
return(folder_results)  # Return results for this folder
}, error = function(e) {
# Log error and move on to next folder
write(paste("Error in folder:", folder, "\n", e$message, "\n"), file = log_file, append = TRUE)
return(NULL)  # Return NULL for folders with errors
})
}
# Stop the cluster
stopCluster(cl)
# Combine all results from all folders
Het_df <- bind_rows(Het_df, results)
# Write final combined results
write_csv(Het_df, file = "final_combined_results.csv")
