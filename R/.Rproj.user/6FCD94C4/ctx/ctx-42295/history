# Define the function
process_csv_column <- function(file_path, column_name, sep) {
# Step 1: Read the CSV file
mydata <- read.csv(file_path)
#Read the column names from the file
mycolumn_names <- read.table(file_path,
nrows = 1,
colClasses = 'character',
header = FALSE,
sep = ",")
#  Check if the column exists
if (!column_name %in% mycolumn_names) {
stop("The specified column does not exist in the dataset.")
}
#Read the dataframe from the file
mydata <- read.table(file_path,
sep = ",",
stringsAsFactors = FALSE,
colClasses = "character",
skip = 1)
colnames(mydata) <- mycolumn_names
namevec <- colnames(mydata)
column_as_dataframe <- read.table(text = mydata[,column_name], sep = sep)
# Return the selected column as a dataframe
return(column_as_dataframe)
}
# Define the function
