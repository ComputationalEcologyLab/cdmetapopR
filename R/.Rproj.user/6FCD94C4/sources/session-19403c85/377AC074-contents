#' Convert CDMetaPOP data to GENEPOP or GENALEX format
#'
#' This function reads a `CDMetaPOP` CSV file, processes the genetic loci, and converts the data into `GENEPOP` or `GENALEX` formats.
#'
#' @param path Character string; the file path to the `CDMetaPOP` CSV file.
#' @param stratum Character string; the column name in the input data that specifies the population (e.g., `PatchID`).
#' @param genepop_file Character string; the file path for the GENEPOP output file. Required if `format` is "genepop".
#' @param genalex_file Character string; the file path for the GENALEX output file. Required if `format` is "genalex".
#'
#' @return The function writes the GENEPOP or GENALEX formatted data to the specified file and returns no object.
#'
#' @examples
#' \dontrun{
#' # Convert a CDMetaPOP file to GENEPOP format
#' path = "~your_path/ind1.csv"
#' cdmetapop_to_gene(
#'   path = path,
#'   stratum = "PatchID",
#'   format = "genepop",
#'   output_file = "cdmetapop_to_genepop_output.gen"
#' )
#'
#' # Convert a CDMetaPOP file to GENALEX format
#' path = "~your_path/ind1.csv"
#' cdmetapop_to_gene(
#'   path = "your_path/ind1.csv",
#'   stratum = "PatchID",
#'   format = "genalex",
#'   output_file = "cdmetapop_to_genalex_output.csv"
#' )
#' }
#' 
#' @details
#' This function was developed with assistance from ChatGPT, an AI language model by OpenAI.
#' 
#' @export
cdmetapop_to_gene <- function(path, stratum = PatchID, genepop_file = NULL, genalex_file = NULL) {
  # Ensure at least one output file is specified
  if (is.null(genepop_file) && is.null(genalex_file)) {
    stop("Please specify at least one of 'genepop_file' or 'genalex_file'.")
  }
  
  # Read the input data
  mydata <- read.csv(path, stringsAsFactors = FALSE)
  col_names <- names(mydata)
  
  # Identify loci columns
  locus_names <- grepl("L[[:digit:]]+A[[:digit:]]+$", col_names)
  loci <- mydata[, col_names[locus_names]]
  df <- mydata[, col_names[!locus_names]]
  locus_names <- names(loci)
  
  # Process loci into alleles
  process_alleles <- function(x) {
    alleles <- which(x != 0) - 1
    if (length(alleles) == 1) alleles <- rep(alleles, 2)
    paste(alleles, collapse = ":")
  }
  
  for (locus in unique(gsub("A[[:digit:]]+$", "", locus_names))) {
    idx <- grep(locus, locus_names)
    alleles <- apply(loci[, idx, drop = FALSE], 1, process_alleles)
    df[[locus]] <- alleles
  }
  
  # Handle GENEPOP output
  if (!is.null(genepop_file)) {
    genepop_output <- file(genepop_file, "w")
    writeLines("CDMetaPOP outfile into Genepop", genepop_output)
    writeLines(unique(gsub("A[[:digit:]]+$", "", locus_names)), genepop_output)
    
    for (pop in unique(df[[stratum]])) {
      writeLines("POP", genepop_output)
      pop_data <- df[df[[stratum]] == pop, ]
      for (i in seq_len(nrow(pop_data))) {
        individual_id <- pop_data$ID[i]
        alleles <- paste(pop_data[i, unique(gsub("A[[:digit:]]+$", "", locus_names))], collapse = " ")
        writeLines(paste(individual_id, alleles, sep = ", "), genepop_output)
      }
    }
    close(genepop_output)
    message("GENEPOP file written to ", output_file)
  }
  
  # Handle GENALEX output
  if (format == "genalex") {
    df$Population <- as.numeric(factor(df[[stratum]]))
    loc_columns <- unique(gsub("A[[:digit:]]+$", "", locus_names))
    allele_matrix <- do.call(cbind, lapply(loc_columns, function(locus) {
      allele_data <- strsplit(as.character(df[[locus]]), ":")
      do.call(rbind, lapply(allele_data, function(a) as.numeric(a)))
    }))
    colnames(allele_matrix) <- rep(loc_columns, each = 2)
    
    genalex_data <- cbind(ID = df$ID, Population = df$Population, allele_matrix)
    write.csv(genalex_data, output_file, row.names = FALSE)
    message("GENALEX file written to ", output_file)
  }
}

