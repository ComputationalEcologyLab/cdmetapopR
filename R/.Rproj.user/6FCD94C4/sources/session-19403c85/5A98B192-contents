We calculated growth both as absolute size change from one year to the next (AG) and as a rate (IGR): 

Absolute growth (AG): \( L_t - L_i \); and
Instantaneous growth rate (IGR): \( \frac{\log L_t - \log L_i}{t} \); 

where Lt is the forklength at recapture and Li is length at the time of release (Lugert et al 2014). Continuous data was checked for assumptions of normality.To determine whether there were significant differences in size and growth between the time of fish release and recapture across the year and release groups, we used analysis of variance (ANOVA) and post-hoc Tukey HSD (respectively aov and TukeyHSD functions part of base stats R package). To test whether condition or length at release would significantly affect yymale growth in the wild we compared with linear regression models (lm in base r), AG and IGR as dependent variables with and without the variables condition and forklenght (ANOVA, aov). Additionally, we subsetted the data into two groups based on the signs of AG and IGR (negative sign denotes shrinking fish) and performed t-tests to compare whether there were significant differences in size at release or distance moved between fish that had negative or positive AG and IGR. 

## Results

```{r warning = FALSE}

growth_year1 <- mydata_first %>%
  arrange(IndividualID, EHYear_Extracted) %>%
  group_by(IndividualID) %>%
  reframe(
    # ABSOLUTE GROWTH
    AG = ForkLength_mm[2] - ForkLength_mm[1],
    # INSTANTANEOUS GROWTH RATE
    IGR = (log(ForkLength_mm[2]) - log(ForkLength_mm [1]))/ (day[2] - day [1]),
    # day
    day = day,
    # size at release
    release_fl = release_fl [1] ,
    # condition
    condition = Condition [1],
    # release year
    release_year =release_year [1],
    # distance moved
    distance_moved = distance_moved [2],
    # release_group
    release_group = release_group_name ) %>%
  group_by(IndividualID) %>%
  slice(2)%>% # Keep only second measurement 
  ungroup()

growth_stats <-growth_year1 %>%
  group_by(release_year) %>%
  summarise(
    avg_AG = mean(AG, na.rm = TRUE),
    avg_IGR = mean(IGR, na.rm = TRUE),
  ) %>%
  ungroup()
#growth_stats

# Fit an ANOVA model for IGR
anova_model_IGR <- aov(IGR ~ release_year + release_group , data = growth_year1)

# Summarize the ANOVA result
tmp_IGR<-tidy(anova_model_IGR)

# Fit an ANOVA model for AG
anova_model_AG <- aov(AG ~ release_year + release_group, data = growth_year1)

# Summarize the ANOVA result
tmp_AG<-tidy(anova_model_AG)

# Combine the tables
combined_table <- rbind(anova_model_IGR, anova_model_AG)

# Full models with both rlease_fl & distance_moved
model_fl_AG <- lm(AG ~ release_fl, data = growth_year1)
model_dist_AG <- lm(AG ~ distance_moved, data = growth_year1)

model_fl_IGR <- lm(IGR ~ release_fl, data = growth_year1)
model_dist_IGR <- lm(IGR ~ distance_moved, data = growth_year1)

# Base models (intercept only)
model_AG_base <- lm(AG ~ 1, data = growth_year1)
model_IGR_base <- lm(IGR ~ 1, data = growth_year1)

# Compare the full and base models
# For AG
AG_anova<-anova(model_AG_base, model_fl_AG, model_dist_AG)

# For IGR
IGR_anova<-anova(model_IGR_base, model_fl_IGR, model_dist_IGR)

# Function to extract adjusted R-squared
get_adj_r2 <- function(model) summary(model)$adj.r.squared

# Compare adjusted R^2 for AG
ag_R<-data.frame(
  Model = c("Base", "FL", "dist"),
  Adjusted_R2 = c(
    get_adj_r2(model_AG_base),
    get_adj_r2(model_fl_AG),
    get_adj_r2(model_dist_AG)
  )
)

# Compare adjusted R^2 for IGR
