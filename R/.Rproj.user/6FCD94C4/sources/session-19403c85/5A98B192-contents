    get_adj_r2(model_fl_IGR),
    get_adj_r2(model_dist_IGR)
  )
)


# Post-hoc tests IGR
tuk_igr_y <- TukeyHSD(anova_model_IGR, "release_year")
tuk_igr_g <- TukeyHSD(anova_model_IGR, "release_group")

# Post-hoc tests AG
tuk_ag_y<-TukeyHSD(anova_model_AG, "release_year")

tuk_ag_g<-TukeyHSD(anova_model_AG, "release_group")


