df.summary <- total %>%
  group_by(Year, Run) %>%
  summarise(
    sd = sd(SelDeaths, na.rm = TRUE),
    len = mean(SelDeaths)
  )
df.summary
 library(ggplot2)
  
#make graph of mean number of  deaths per patch
p<- ggplot(df.summary, aes(y = len, x = Year, color = Run, fill=Run)) +
  geom_line() +
  geom_point() +
  scale_color_manual(values = color_blind_palette) + # Apply colorblind palette
  geom_ribbon(aes(ymin = len-sd, ymax =  len+sd, fill = Run), alpha = 0.3, linetype=0) + 
  labs(x="Year", y = "Ohomo")  + 
  theme_bw(base_size = 15)+
  annotate(geom = "rect", xmin = 25, xmax = 38, ymin = -Inf, ymax = Inf,
           fill = "grey",  alpha = 0.2) +
  #annotate(geom = "rect", xmin = 25, xmax = 28, ymin = -Inf, ymax = Inf,
           #fill = "grey", alpha = 0.3) +
  annotate("text", x=33, y=32, label= "MYY") + 
  annotate("text", x = 31.5, y=27, label = "Suppression")+
  ggtitle ("Selection Runs: Mean number of Deaths") +
  ylab("Mean Number Deaths Per Patch") + theme_bw(base_size = 15)

p + geom_segment(aes(x = 25, y = 25, xend = 38, yend = 25), inherit.aes = FALSE) + geom_segment(aes(x = 28, y = 30, xend = 38, yend = 30), inherit.aes = FALSE)

