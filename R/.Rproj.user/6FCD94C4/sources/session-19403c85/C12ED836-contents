#calculate proportion of selection deaths over time

InitN$totalN <- InitN$N*415
InitN$totalSD <- InitN$SelDeaths*415
InitN$propSD <- (InitN$totalSD/InitN$totalN)
xxxx<-InitN[InitN$Run != "+1 SD (12.44)", ] 

df.summary2 <- xxxx %>%
  group_by(Year, Run) %>%
  summarise(
    sd = sd(propSD, na.rm = TRUE),
    len = mean(propSD)
  )
df.summary2
ggplot(df.summary2, aes(y = len, x = Year, color = Run, ymin = len-sd, ymax = len+sd)) +
  geom_line() +
  geom_pointrange(size=0.1)+
  scale_color_manual(values = color_blind_palette) + # Apply colorblind palette
  annotate(geom = "rect", xmin = 25, xmax = 38, ymin = -Inf, ymax = Inf,
           fill = "grey",  alpha = 0.3) +
  ggtitle ("Selection Runs") +
  ylab("Proportion of deaths") + theme_bw(base_size = 15)

