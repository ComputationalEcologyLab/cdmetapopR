#Eigenvalues
(ev<-env.pca$CA$eig)
# Apply Kaiser-Guttman criterion to select axes
ev[ev > mean(ev)]
#Broken stick model
n<- length(ev)
bsm <- data.frame(j = seq(1:n), p=0)
bsm$p[1] <- 1/n
for(i in 2:n){
}
bsm$p <- 100*bsm$p/n
bsm
# plot eigenvalues and % variance for each axis
par(mfrow=c(2,1))
barplot(ev, main = "Eigenvalues", col = "bisque", las = 2)
abline (h = mean (ev), col = "red")
# plot eigenvalues and % variance for each axis
par(mfrow=c(2,1))
barplot(ev, main = "Eigenvalues", col = "bisque", las = 2)
abline (h = mean (ev), col = "red") #average eigenvalues
legend("topright", "Average eigenvalue", lwd = 1, col = 2, bty = "n")
barplot(t(cbind(100*ev/sum(ev),
bsm$p[n:1])),
beside = TRUE,
main = "%variance",
col = c("bisque", 2),
las = 2)
legend("topright",
c("% eigenvalue", "Broken stick model"),
pch = 15,
col = c("bisque", 2)
bty = "n")
legend("topright",
c("% eigenvalue", "Broken stick model"),
pch = 15,
col = c("bisque", 2) ,
bty = "n")
