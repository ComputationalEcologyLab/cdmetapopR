if (nrow(env.de) != ncol(env.de)) {
stop("Input matrix must be square.")
}
summary(env.de)
coldiss <- function(D, nc = 4, byrank = TRUE, diag = TRUE) {
# Ensure D is a matrix
D <- as.matrix(D)
# Check if square matrix
if (nrow(D) != ncol(D)) {
stop("Input matrix must be square.")
}
# Rank transformation if specified
if (byrank) {
rankD <- rank(D)
D <- matrix(rankD, nrow = nrow(D))
}
# Handle diagonal if requested
if (!diag) {
diag(D) <- NA
}
# Create color palette
library(RColorBrewer)
colors <- colorRampPalette(brewer.pal(nc, "YlOrRd"))(100)
# Plot image
image(
1:ncol(D), 1:nrow(D), t(D[nrow(D):1, ]),
col = colors, xlab = "", ylab = "",
xaxt = 'n', yaxt = 'n'
)
axis(1, at = 1:ncol(D), labels = colnames(D), las = 2, cex.axis = 0.7)
axis(2, at = 1:nrow(D), labels = rownames(D), las = 2, cex.axis = 0.7)
}
coldiss(env.de, diag=TRUE)
