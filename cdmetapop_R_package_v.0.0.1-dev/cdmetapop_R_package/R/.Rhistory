coldiss <- function(D, nc = 4, byrank = TRUE, diag = FALSE) {
if (byrank) {
rankD <- rank(D)
D <- matrix(rankD, nrow = nrow(D))
}
diag(D) <- NA
library(RColorBrewer)
colors <- colorRampPalette(brewer.pal(nc, "YlOrRd"))(100)
image(1:ncol(D), 1:ncol(D), D, col = colors, xlab = "", ylab = "")
}
coldiss(env.de, diag=TRUE)
