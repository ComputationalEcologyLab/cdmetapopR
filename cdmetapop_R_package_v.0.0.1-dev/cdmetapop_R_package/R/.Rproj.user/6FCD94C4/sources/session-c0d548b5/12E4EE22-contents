################################################################
#RDA on the environmental variables#### GEOMORPHIC ENVIRONMENT
###############################################################
# since variables are expressed in different measurement scales, we compute a PCA on the correlation matrix
# Correlations are the covariances of standardized variables

# Merge the data by "Site"
merged_df <- merge(growth, geo_env, by = "SamplingUnitName")
merged_df <- na.omit(merged_df)
# Save the 'Site' column
site_info <- merged_df$SamplingUnitName
species_info <- merged_df$SpeciesCode

# Response data: individual measurements
response_data <- as.data.frame(scale(merged_df[, c(3,4,6,7)]))
# Explanatory data: environmental variables
explanatory_data <- as.data.frame(scale(merged_df[, c(8:22)][, sapply(merged_df[, c(8:22)], is.numeric)]))
 
# Perform RDA
rda_result <- rda(response_data ~ ., data = explanatory_data)
# Extract RDA site scores
site_scores <- as.data.frame(scores(rda_result, display = "sites", scaling = 2))

# Add the 'Site' information
site_scores$species <- species_info

# Assuming you have already run your RDA model and have the necessary data
library(vegan)
library(ggplot2)
library(grid)

# Assuming your RDA model is stored in rda_result
# Example: rda_result <- rda(response_data ~ ., data = explanatory_data)

# Step 1: Extract scores from your RDA result
# Explanatory variable scores (arrows)
explanatory_scores <- scores(rda_result, display = "bp", scaling = 2)

# Response variable scores (species or other response variables)
response_scores <- scores(rda_result, display = "species", scaling = 2)

# Site scores (individual sites, to color points)
site_scores <- scores(rda_result, display = "sites", scaling = 2)

# Step 2: Convert scores into data frames for ggplot
explanatory_df <- as.data.frame(explanatory_scores)
response_df <- as.data.frame(response_scores)
site_df <- as.data.frame(site_scores)

# Add explanatory variable names for labeling arrows
explanatory_df$Variable <- rownames(explanatory_df)

# Add  names for site labels
site_df$Site <- species_info

# Step 3: Create a color mapping for the sites (optional)
# For example, if site labels are categorical, you can color them accordingly
site_df$Site <- as.factor(site_df$Site)  # Convert sites to factor if needed

#Create a color mapping for the sites
# Generate enough colors for all unique sites
num_sites <- length(unique(site_df$Site))
site_colors <- colorRampPalette(RColorBrewer::brewer.pal(3, "Set2"))(num_sites)

# Step 4: Plot the RDA biplot
ggplot() +
  # Plot explanatory variables as arrows
  geom_segment(data = explanatory_df, 
               aes(x = 0, y = 0, xend = RDA1, yend = RDA2),
               arrow = arrow(length = unit(0.2, "cm")), 
               color = "black") +
  # Add explanatory variable labels (arrows)
  geom_text(data = explanatory_df, 
            aes(x = RDA1, y = RDA2, label = Variable), 
            color = "black", hjust = 1.5, size = 2.5) +
  # Plot site scores as points (colored)
   geom_point(data = site_df, 
              aes(x = RDA1, y = RDA2, color = Site), 
              size = 1, alpha = 0.3) +
  # # # Add labels for sites if needed (e.g., site names)
  # geom_text(data = site_df, 
  #           aes(x = RDA1, y = RDA2, label = Site), 
  #           color = "black", vjust = -1, size = 3) +
  # Add response variable points (blue)
  geom_point(data = response_df, 
             aes(x = RDA1, y = RDA2), 
             color = "blue", size = 4, shape = 17) +  # Change shape if needed
  # Add labels for response variables
  geom_text(data = response_df, 
            aes(x = RDA1, y = RDA2, label = rownames(response_df)), 
            color = "blue", vjust = 1.5, size = 3) +
  # Customize theme
  theme_minimal() +
  scale_color_manual(values = site_colors) + 
  labs(x = "RDA1", y = "RDA2", 
       title = "RDA on Geomorphic Explanatory Variables and Species",
       subtitle = "Black arrows: Geomorphic Variables, Blue triangles: Response Variables",
       caption = "Sites colored by Species")


