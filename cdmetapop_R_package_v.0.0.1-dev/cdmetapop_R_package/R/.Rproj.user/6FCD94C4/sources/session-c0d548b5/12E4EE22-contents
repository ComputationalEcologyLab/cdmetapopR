library(ade4)
library(vegan)
library(gclus)
library(ape)
library(dplyr)


mycaps <- read.csv("~/UM/Growth_YYEBT/data/mycaps.csv")
# Convert variables to factors
mycaps$IndividualID <- as.character(mycaps$IndividualID)
mycaps$EHYear_Extracted <- as.factor(mycaps$EHYear_Extracted)

# Keep only IndividualIDs that have more than 1 occurrence
mycaps <- mycaps %>%
  filter(!is.na(ForkLength_mm))%>%
    group_by(IndividualID) %>%
  filter(n() > 1) %>%  
  filter(EHYear_Extracted != 2023)%>%
  ungroup()
mycaps_first <- mycaps %>%
  filter(day == 0 | (day > 100 & day < 450))%>%
  # now make sure I only have two measures per individual, in case I have more than two, make sure the first one is day = 0, and 
  # the next one that immediately follows
  group_by(IndividualID)%>%
  arrange(day)%>%
  slice(c(1,which(day > 0) [1]))%>% # Keep day = 0 and the next
  ungroup()
# build growth df
growth <- mycaps_first %>%
  arrange(IndividualID, EHYear_Extracted) %>%
  group_by(IndividualID) %>%
  reframe(
    # ABSOLUTE GROWTH
    AG = ForkLength_mm[2] - ForkLength_mm[1],
    # INSTANTANEOUS GROWTH RATE
    IGR = (log(ForkLength_mm[2]) - log(ForkLength_mm [1]))/ (day[2] - day [1]),
    # Species
    SpeciesCode = SpeciesCode[1],
    # condition
    condition = Condition [1],
    # distance moved
    distance_moved = distance_moved [2],
    # Sampling_unit
    SamplingUnitName = SamplingUnitName [1]
   )
growth <- growth[!is.na(growth$AG), ]

#myenv <- read.csv("~/UM/Growth_YYEBT/data/myenv.csv")#, colClasses = c("avg_pool_area" = "numeric"))
myenv <- read_csv("myenv.csv", col_types = cols(avg_pool_area = col_number()))
geo_env <- myenv[,c(5:20)]
hab_env <- myenv[,c(5,21:25)]
pool_env <- myenv[,c(5,26:30)]
sub_env <- myenv[,c(5,31:36)]
wood_env <- myenv[,c(5,37:41)]
bank_env <- myenv[,c(5,42:45)]
log_env <- myenv[,c(5,46:50)]
#write.csv(myenv[,c(6:20)], file = "geo_env.csv")

# check for env normality
normality_results <- sapply(myenv, function(col) {
  if (is.numeric(col)) {  # Apply only to numeric variables
    # Kolmogorov-Smirnov test for normality
    ks_test <- ks.test(col[!is.na(col)], "pnorm", mean(col, na.rm = TRUE), sd(col, na.rm = TRUE))
    ks_test$p.value
  } else {
    NA  # Ignore non-numeric columns
  }
})

normality_summary <- data.frame(
  Variable = names(normality_results),
  P_Value = normality_results,
  Normally_Distributed = ifelse(normality_results > 0.05, "Yes", "No")
)


my_units<-unique(mycaps$SamplingUnitName)

myenv<-myenv%>%
  filter(SamplingUnitName %in% my_units)

