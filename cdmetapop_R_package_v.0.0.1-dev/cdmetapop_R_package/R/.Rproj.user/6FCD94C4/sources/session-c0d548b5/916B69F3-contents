Table 5. Model summary outputs giving the predictor variables included after 'dredge' iterations, their estimates, standard error, t statistic, p-values, lower and higher confidence intervals. The estimate for the intercept refers to the categories was the year: 2018.

```{r warning = FALSE}

model_y1 <- lm (IGR ~  condition  +  first_year +  length + weight + distance_moved, data = growth_year1)

#iterate between the different models: 
options(na.action = "na.fail") 
linmodel_y1 <- dredge(model_y1)
options(na.action = "na.omit")# reset na.action options
top_linearmodel_y1 <- subset(linmodel_y1, delta < 2)

# Extract model results
tidy_model <- tidy(model_y1, conf.int = TRUE)

# Format numeric values in scientific notation
tidy_model <- tidy_model %>%
  mutate(
    estimate = format(estimate, scientific = TRUE, digits = 2),
    p.value = format(p.value, scientific = TRUE, digits = 2),
    conf.low = format(conf.low, scientific = TRUE, digits = 2),
    conf.high = format(conf.high, scientific = TRUE, digits = 2)
  )
  

# Generate the table using gt
gt_table <- tidy_model %>%
  gt() %>%
  tab_header(
    title = "IGR Linear Model Results",
  ) %>%
  cols_label(
    term = "Variable",
    estimate = "Estimate",
    conf.low = "CI Lower",
    conf.high = "CI Upper",
    p.value = "P-value"
  ) %>%
  fmt_scientific(
    columns = c(estimate, std.error, statistic, p.value),
    decimals = 2
  ) %>%
  tab_options(
    table.font.size = "medium"
  )

gt_table
```

