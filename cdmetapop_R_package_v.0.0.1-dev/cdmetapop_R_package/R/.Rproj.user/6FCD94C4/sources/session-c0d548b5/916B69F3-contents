## Results

```{r warning = FALSE}

growth_year1 <- mydata_first %>%
  arrange(IndividualID, EHYear_Extracted) %>%
  group_by(IndividualID) %>%
  reframe(
    # ABSOLUTE GROWTH
    AG = ForkLength_mm[2] - ForkLength_mm[1],
    # ABSOLUTE GROWTH RATE
    AGR = (ForkLength_mm[2] - ForkLength_mm [1])/ (day[2] - day [1]),
    #AGR_summer_days = (ForkLength_mm[2] - ForkLength_mm [1])/ (summer_days),
    #AGR_winter_days = (ForkLength_mm[2] - ForkLength_mm [1])/ (day[2] - day [1]- winter_days),
    # RELATIVE GROWTH RATE
    RGR = ((ForkLength_mm[2] - ForkLength_mm [1])/ForkLength_mm [1])*100,
    # INSTANTANEOUS GROWTH RATE
    IGR = (log(ForkLength_mm[2]) - log(ForkLength_mm [1]))/ (day[2] - day [1]),
    #IGR_summer_days = (log(ForkLength_mm[2]) - log(ForkLength_mm [1]))/ (summer_days),
    #IGR_winter_days = (log(ForkLength_mm[2]) - log(ForkLength_mm [1]))/ (day[2] - day [1] - winter_days),
    #IGR_mod = 100 * (log(ForkLength_mm[2] /ForkLength_mm [1])) / (day[2] - day [1]),
    # SPECIFIC GROWTH RATE
    SGR = ((log(ForkLength_mm[2]) - log(ForkLength_mm [1]))/ day[2] - (day [1]))*100,
    #SGR_summer_days = ((log(ForkLength_mm[2]) - log(ForkLength_mm [1]))/ summer_days)*100,
    #SGR_winter_days = ((log(ForkLength_mm[2]) - log(ForkLength_mm [1]))/ day[2] - (day [1] - winter_days))*100,
    # THERMAL GROWTH COEFFICIENT
    #TGC = calculate_tgc (ForkLength_mm[2], ForkLength_mm[1], summer_days, winter_days, GrowthTemperatureBack, GrowthTemperatureOut),
    # SUMMER THERMAL GROWTH COEFFICIENT
    #STGC = calculate_stgc (ForkLength_mm[2], ForkLength_mm[1], summer_days, winter_days, GrowthTemperatureBack, GrowthTemperatureOut), 
        # condition
    condition = Condition [1],
     # distance moved
    distance_moved = distance_moved [2],
    # weigth
    weight = Weight_g [1],
    # length
    length = ForkLength_mm [1],
    # year
    first_year = first_year[1])


growth_stats <-growth_year1 %>%
  group_by(first_year) %>%
  summarise(
    avg_AG = mean(AG, na.rm = TRUE),
    avg_AGR = mean(AGR, na.rm = TRUE),
    avg_RGR = mean(RGR, na.rm = TRUE),
    avg_IGR = mean(IGR, na.rm = TRUE),
    avg_SGR = mean(SGR, na.rm = TRUE),
  ) %>%
  ungroup()
#growth_stats

# store results
gf <- c()
mpd <- c()

# Loop through each column
for (i in 2:ncol(growth_year1)-1) {
  # linear model
  model <- lm (growth_year1[[i]] ~  condition  +  first_year +  length + weight + distance_moved , data = growth_year1)
  
  # Calculate R-squared for the model
  r_squared_value <- summary(model)$r.squared
  gf <- c(gf, r_squared_value)
  
  # Calculate Mean Percentage Deviation (MPD) of each growth calculation
  mean_observed <- mean(growth_year1[[i]]) # calculate the mean
  absolute_deviations <- abs(growth_year1[[i]] - mean_observed) # calculate the deviation from the mean
  mpd_value <- mean(abs((absolute_deviations - mean_observed) * 100)) # calculate the percentage variation
  mpd <- c(mpd, mpd_value)
}

# Create a summary table with results
results <- data.frame(
  Model = names(growth_year1[, c(2:6)]),
  R_squared = gf[2:6],
  Mean_Percentage_Deviation = mpd[2:6]
)
smallest_change_fl<- growth_year1%>% filter(AG == min(growth_year1$AG))#id 17482
min_IGR <- growth_year1%>% filter(IGR == min(growth_year1$IGR))#id 	17239

largest_change_fl<- growth_year1%>% filter(AG == max(growth_year1$AG))#id 14999
max_IGR <- growth_year1%>% filter(IGR == max(growth_year1$IGR))#id 14999
#  negative & positive selected values
negative_ids <- growth_year1 %>%
  filter(AG < 0) %>%   # Filter rows with negative growth
  summarise(count = n_distinct(IndividualID),
            minAG = min(AG),
            avgAG = mean(AG),
            avgdist = mean(distance_moved),
            avgfl = mean(length))  


positive_ids <- growth_year1 %>%
  filter(AG > 0) %>%   # Filter rows with positive growth
  summarise(count = n_distinct(IndividualID),
            minAG = min(AG),
            avgAG = mean(AG),
            avgdist = mean(distance_moved),
            avgfl = mean(length))  



