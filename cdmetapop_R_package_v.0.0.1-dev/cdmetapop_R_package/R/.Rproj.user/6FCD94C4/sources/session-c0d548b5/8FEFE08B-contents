library(ggplot2)

######################################
### ID PENALTY ######################
#####################################

# Define slopes and standard deviation
m <- 9.57
sd <- 12.44-m
bint <- -7.025   

# Slopes to plot
slopes <- c(
  m,
  m + sd, m - sd,
  m + 0.25 * sd, m - 0.25 * sd,
  m + 0.125 * sd, m - 0.125 * sd
)

# Generate data frame with x values
Ho <- seq(0, 1, by = 0.01)
lines_df <- data.frame()


# Create y-values for each slope
for (m in slopes) {
  # Calculate mortality probability using logit transformation
  logit_mortality <- bint + m * Ho
  mortality_prob <- exp(logit_mortality) / (1 + exp(logit_mortality))
  lines_df <- rbind(lines_df, data.frame(x = Ho, y = mortality_prob, m = as.factor(m)))
}

# Plot
ggplot(lines_df, aes(x = x, y = y, color = m)) +
  geom_line(size = 1) +
  theme_minimal() +
  labs(
    title = "Hypothesis",
    x = "Ho",
    y = "mortality",
    color = "Slope"
  ) +
  scale_color_manual(values = color_blind_palette[1:7])  

