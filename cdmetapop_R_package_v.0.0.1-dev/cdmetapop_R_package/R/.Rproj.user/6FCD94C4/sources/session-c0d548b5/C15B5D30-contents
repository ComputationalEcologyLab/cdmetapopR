##################### FEMALE EGG LAYING ##################### 

eggs <- matrix(data=NA, nrow=2, ncol=11)
runs <- c(0:9)

for (i in (1:10)) {
  foo <- read.csv(paste0("./run0batch0mc",runs[i],"species0/ind99.csv"))
  
  bar <- foo[foo$sex=="XX",]
  bar1 <- bar[bar$mature==1,]
  
  eggs[1,i] <- sum(bar1$mature)
  eggs[2,i] <- sum(bar1$layeggs)
  
}

eggs[,11] <- rowMeans(eggs, na.rm=T)

colnames(eggs) <- c(paste0("MC", runs), "Avg")
row.names(eggs) <- c("Number_females","Egg_laying_females")

eggs 



